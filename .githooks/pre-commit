#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

if ! command -v pyftsubset >/dev/null 2>&1 && ! python3 -m fontTools.subset --help >/dev/null 2>&1; then
  echo "pre-commit: fonttools is required to rebuild subset fonts." >&2
  echo "Install it with: python3 -m pip install --user fonttools brotli zopfli" >&2
  exit 1
fi

echo "pre-commit: rebuilding subset fonts..."
bash scripts/subset-fonts.sh

git add src/app/fonts/*.woff2
echo "pre-commit: subset fonts are up to date."
